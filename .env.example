# Template de variáveis de ambiente.
# Copie este arquivo para .env (que está no .gitignore) e preencha com suas chaves.
#
# Para rodar localmente:
#   cp .env.example .env
#   # edite .env com suas chaves
#   # no terminal, antes de rodar o pipeline:
#   export $(grep -v '^#' .env | xargs)
#
# No GitHub Actions, configure cada uma destas como Secret em
# Settings > Secrets and variables > Actions.

# --- APIs de geração de conteúdo ---
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...
PEXELS_API_KEY=...

# --- YouTube OAuth2 ---
# Conteúdo JSON COMPLETO do client_secrets.json (baixado do Google Cloud Console)
# Para colar numa linha só, use: cat client_secrets.json | jq -c . (ou só copie removendo quebras)
YOUTUBE_CLIENT_SECRETS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["..."]}}

# Conteúdo JSON COMPLETO do youtube_token.json (gerado pelo generate_youtube_token.py)
YOUTUBE_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"...","client_id":"...","client_secret":"...","scopes":["..."],"expiry":"..."}

# --- Flags opcionais ---
# Permite fluxo interativo de OAuth (só para rodar localmente pra gerar token)
ALLOW_INTERACTIVE_AUTH=0
