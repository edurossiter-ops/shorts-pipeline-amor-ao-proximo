# ============================================================
# CREDENCIAIS — NUNCA COMMITAR
# ============================================================
.env
.env.local
.env.*.local
*.env

# YouTube OAuth
client_secrets.json
youtube_token.json
token.json

# Qualquer arquivo que pareça chave
*secret*
*_key.*
*apikey*

# ============================================================
# Dados gerados pelo pipeline (ciclos, logs, vídeos)
# ============================================================
data/
cycles/
control/
*.log

# vídeos e áudios eventualmente soltos na raiz
*.mp4
*.mp3
*.wav
*.srt
*.ass
!configs/**/*.mp4
# Fixtures de teste SÃO commitáveis
!tests/fixtures/*.mp3
!tests/fixtures/*.mp4
!tests/fixtures/*.wav

